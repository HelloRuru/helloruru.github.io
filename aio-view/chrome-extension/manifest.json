{
  "manifest_version": 3,
  "name": "AIO View Detector",
  "version": "1.1.0",
  "description": "在 Google 搜尋頁自動偵測 AI Overview，回傳結果給 AIO View。",
  "homepage_url": "https://lab.helloruru.com/aio-view/",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "AIO View Detector",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/search*",
        "*://www.google.com.tw/search*",
        "*://www.google.co.jp/search*",
        "*://www.google.co.uk/search*",
        "*://www.google.com.hk/search*",
        "*://www.google.com.sg/search*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://lab.helloruru.com/aio-view/*",
        "https://helloruru.github.io/aio-view/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
